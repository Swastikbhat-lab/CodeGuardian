# CodeGuardian Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# LLM API KEYS
# ============================================
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# OBSERVABILITY (Langfuse)
# ============================================
# Sign up at: https://cloud.langfuse.com (FREE tier)
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# DATABASE
# ============================================
# For local development (after running: createdb codeguardian)
DATABASE_URL=postgresql://localhost:5432/codeguardian

# For production (Railway, Render, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/codeguardian

# ============================================
# REDIS
# ============================================
# For local development
REDIS_URL=redis://localhost:6379/0

# For production
# REDIS_URL=redis://user:password@host:6379/0

# ============================================
# GITHUB INTEGRATION (Optional)
# ============================================
# Get from: https://github.com/settings/tokens
# Only needed if you want GitHub PR integration
GITHUB_TOKEN=

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# COST LIMITS
# ============================================
# Maximum cost per review in USD
MAX_COST_PER_REVIEW=5.00

# Maximum tokens per review
MAX_TOKENS_PER_REVIEW=100000

# ============================================
# AGENT CONFIGURATION
# ============================================
# Enable/disable specific agents
ENABLE_STATIC_ANALYSIS=true
ENABLE_SECURITY_SCAN=true
ENABLE_LOGIC_ANALYSIS=true
ENABLE_TEST_GENERATION=true
ENABLE_AUTO_FIX=false  # Keep false until you're confident!

# Parallel execution
PARALLEL_AGENT_EXECUTION=true
MAX_PARALLEL_AGENTS=4

# ============================================
# CODE ANALYSIS
# ============================================
# Maximum file size to analyze (in MB)
MAX_FILE_SIZE_MB=10

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=python,javascript,typescript

# ============================================
# CLAUDE MODEL CONFIGURATION
# ============================================
# Primary model for complex reasoning
PRIMARY_MODEL=claude-sonnet-4-20250514

# Quick model for simple tasks
QUICK_MODEL=claude-haiku-4-20250514

# Temperature for code analysis (lower = more deterministic)
ANALYSIS_TEMPERATURE=0.3

# ============================================
# SECURITY
# ============================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_generate_with_openssl

# Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# FILE STORAGE (Optional - for production)
# ============================================
# S3 or compatible storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=codeguardian-files
# S3_REGION=us-east-1

# ============================================
# FRONTEND
# ============================================
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# MONITORING & ALERTS
# ============================================
# Email for error notifications (optional)
# ADMIN_EMAIL=your-email@example.com

# Slack webhook for notifications (optional)
# SLACK_WEBHOOK_URL=
